{
  "name": "rbx-tsx",
  "version": "0.1.0",
  "description": "TSX to Luau compiler targeting react-lua for Roblox",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AlroviOfficial/rbx-tsx.git"
  },
  "homepage": "https://github.com/AlroviOfficial/rbx-tsx",
  "bugs": {
    "url": "https://github.com/AlroviOfficial/rbx-tsx/issues"
  },
  "keywords": [
    "roblox",
    "tsx",
    "luau",
    "react",
    "react-lua",
    "compiler",
    "transpiler",
    "rojo",
    "jsx"
  ],
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "rbx-tsx": "./dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npx tsx ./src/index.ts  compile ../Factions/factions/Src -o out",
    "builddemo": "npx tsx ./src/index.ts  compile ./demo/src -o out",
    "test": "npx tsx --test",
    "dev": "npm run src/index.ts",
    "generate": "npm run scripts/generate-types.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "types/",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "@types/node": "^25.9.1",
    "tailwindcss": "^4.1.18",
    "yaml": "^2.8.2"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "typescript": "^5.8.3"
  }
}
